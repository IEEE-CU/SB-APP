echo "Running Husky pre-commit checks..."

# 1. Basic Local Secret Check
STAGED_SECRETS=$(git diff --cached --name-only | grep -E '\.env(\..+)?$|\.pem$|\.key$|\.p12$|\.pfx$|id_rsa$' || true)
if [ -n "$STAGED_SECRETS" ]; then
  echo "❌ ERROR: You are trying to commit potential secrets!"
  echo "The following files must be in .gitignore and never committed:"
  echo "$STAGED_SECRETS"
  echo "Please remove them from the commit and add them to .gitignore."
  exit 1
fi

# 2. Advanced Secret Check (Trufflehog) - runs if installed locally
if command -v trufflehog >/dev/null 2>&1; then
  echo "🔒 Running advanced secret scan with TruffleHog..."
  trufflehog filesystem . --only-verified --fail || exit 1
else
  echo "⚠️ trufflehog binary not found locally. Skipping advanced secret scan."
  echo "   (It will still run on GitHub Actions. To run locally, install trufflehog: https://github.com/trufflesecurity/trufflehog)"
fi

# 3. Security Audits (npm audit)
echo "🛡️ Checking if security audits are needed..."
if [ -f "frontend/package.json" ]; then
  if git diff --cached --name-only | grep -q '^frontend/package'; then
    echo "Auditing frontend..."
    (cd frontend && npm audit --audit-level=high) || exit 1
  fi
fi

if [ -f "backend/package.json" ]; then
  if git diff --cached --name-only | grep -q '^backend/package'; then
    echo "Auditing backend..."
    (cd backend && npm audit --audit-level=high) || exit 1
  fi
fi

# 4. Lint and Format (lint-staged)
echo "💅 Running lint-staged (formatting)..."
npx lint-staged
