# Environment Variables
PORT=3001
NODE_ENV=development

# MongoDB Connection (MongoDB Atlas)
# Replace username, password, and cluster-url with your actual values
MONGODB_URI=mongodb+srv://username:password@cluster-name.xxxxx.mongodb.net/ieee_finance?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Google Gemini API (for AI insights)
GEMINI_API_KEY=your-gemini-api-key

# Load balancing: fork one worker process per CPU core (set to "true" in production)
ENABLE_CLUSTER=false
# Optional: override the number of workers (defaults to os.cpus().length)
# WEB_CONCURRENCY=4

# Mongoose connection pool size (per worker process)
DB_MAX_POOL_SIZE=20
DB_MIN_POOL_SIZE=2

# Initial DB connection retry behavior (server stays up and /api/health
# reports 503 if all retries are exhausted, rather than exiting the process)
DB_CONNECT_MAX_RETRIES=5
DB_CONNECT_RETRY_DELAY_MS=5000
